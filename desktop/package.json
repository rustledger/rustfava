{
  "name": "rustfava-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "ensure-rustledger": "bun run scripts/ensure-rustledger.ts",
    "ensure-rustledger:main": "bun run scripts/ensure-rustledger.ts --main",
    "ensure-rustledger:update": "bun run scripts/ensure-rustledger.ts --update",
    "ensure-rustledger:force": "bun run scripts/ensure-rustledger.ts --force",
    "tauri:dev": "bun run ensure-rustledger && tauri dev",
    "tauri:dev:main": "bun run ensure-rustledger:main && tauri dev",
    "tauri:build": "bun run ensure-rustledger && tauri build"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "tauri-pty": "^0.2.1"
  }
}
